# OVH-BUY 项目根 .gitignore
# 结构:
#   server/   - Go 后端 (Gin)
#   web/      - 前端 (Vite + TanStack Router + shadcn-ui)
# 子目录有各自的 .gitignore；这里只列跨目录通用规则 + Go 后端运行时数据

# ============== 通用 / OS ==============
.DS_Store
Thumbs.db
*.swp
*.swo
*.sw?

# ============== 编辑器 / IDE ==============
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ============== 环境变量 ==============
# 所有 .env 一律不入库，避免泄密钥。需要分享配置示例请提交 .env.example
.env
.env.*
*.env
!*.env.example

# ============== 日志 ==============
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============== Go 后端 (server/) ==============
# 编译产物
server/server
server/server.exe
server/main
server/main.exe
*.exe
# 运行时数据（含密钥 / 状态）
server/data/
server/cache/
server/logs/
# Go 本地缓存
server/vendor/
# 测试覆盖率
*.test
*.out

# ============== 前端 (web/) ==============
# 主要由 web/.gitignore 处理，这里加双保险
web/node_modules/
web/dist/
web/dist-ssr/
web/.next/
# TanStack Router 开发缓存
web/.tanstack/
# TanStack Router 自动生成路由树
web/src/routeTree.gen.ts
# TS 增量构建缓存
web/*.tsbuildinfo

# ============== 顶层旧前端残留（已删除，留规则防止 reorg 时回流）==============
/node_modules/
/dist/
/build/
/.next/
