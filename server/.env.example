# ==============================================
# OVH Phantom Sniper (Go server) - 配置文件
# 复制此文件为 .env 并修改配置值
# ==============================================

# API 安全密钥（用于验证前后端通信）
# 生成方法: openssl rand -base64 32
# 与前端设置页中的密钥保持一致
API_SECRET_KEY=123456

# 后端端口
PORT=19998

# 调试模式（开发: true, 生产: false）
DEBUG=false

# 是否启用 API 密钥验证
ENABLE_API_KEY_AUTH=true

# 数据目录（共享 Python 后端数据，零迁移）
# 默认指向上级目录的 server/data
DATA_DIR=../server/data
CACHE_DIR=../server/cache
LOGS_DIR=../server/logs

# Gin 模式: debug / release
GIN_MODE=release
